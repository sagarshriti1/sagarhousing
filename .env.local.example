# Cypress End-to-End Test Credentials
# To run authenticated Cypress tests, copy this file to .env.local 
# and populate it with real test accounts from your Supabase database.
# Note: .env.local is ignored in git, so your credentials will not be saved.

TEST_USER_EMAIL=test-user@sagarhousing.com
TEST_USER_PASSWORD=YourSecurePassword123

TEST_REALTOR_EMAIL=test-realtor@sagarhousing.com
TEST_REALTOR_PASSWORD=YourSecurePassword123

TEST_ADMIN_EMAIL=test-admin@sagarhousing.com
TEST_ADMIN_PASSWORD=YourSecurePassword123
